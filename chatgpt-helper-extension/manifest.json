{
  "manifest_version": 3,
  "name": "ChatGPT Context Helper",
  "version": "1.0.1",
  "description": "Estimate visible token usage in ChatGPT and copy formulas as LaTeX or Markdown.",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "ChatGPT Context Helper",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
